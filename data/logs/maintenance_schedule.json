      {
        "asset_id": "CNC-001",
        "asset_name": "CNC Vertical Milling Machine",
        "criticality": "High",
        "maintenance_program": {

          "daily_tasks": {
            "frequency": "Every Shift",
            "estimated_time_minutes": 25,
            "responsible_role": "Operator",
            "tasks": [
              "Check coolant level and refill if below 70%",
              "Inspect spindle sound at idle and 5000 RPM",
              "Check lubrication system pressure gauge",
              "Clean chip conveyor and machine bed",
              "Verify emergency stop functionality"
            ]
          },

          "weekly_tasks": {
            "frequency": "Every 7 Days",
            "estimated_time_hours": 1.5,
            "responsible_team": "Mechanical Maintenance",
            "tasks": [
              "Check axis backlash using dial indicator",
              "Inspect way covers for damage",
              "Inspect lubrication lines for leakage",
              "Check hydraulic pressure stability",
              "Test safety door interlock switches"
            ]
          },

          "monthly_tasks": {
            "frequency": "30 Days",
            "planned_downtime_hours": 3,
            "tasks": [
              "Clean electrical cabinet filters",
              "Thermal scan of electrical panel",
              "Check spindle runout (<0.005 mm)",
              "Inspect ball screws and linear guides",
              "Coolant concentration testing (6-8%)",
              "Test UPS backup power"
            ],
            "required_spares_preplanned": [
              "Lubrication Oil 2L",
              "Coolant Concentrate 1L"
            ]
          },

          "quarterly_tasks": {
            "frequency": "90 Days",
            "planned_downtime_hours": 4,
            "tasks": [
              "Laser alignment verification",
              "Servo motor inspection",
              "Encoder signal verification",
              "Inspect tool changer mechanism",
              "Electrical torque tightening audit"
            ]
          },

          "annual_overhaul": {
            "frequency": "12 Months",
            "planned_shutdown_days": 2,
            "tasks": [
              "Complete spindle inspection",
              "Replace critical bearings",
              "Replace lubrication filters",
              "Control cabinet deep cleaning",
              "Firmware update",
              "Full machine geometric calibration"
            ],
            "estimated_budget": 2500
          }
        }
      },

